# daily-digest.env — config for ops/elitedesk/daily-digest.sh
# Copy to daily-digest.env (gitignored) and fill in. The mail *credential*
# (Gmail app password) lives in ~/.msmtprc, NOT here — see README.md.

# Where the digest is sent, and the From header (both usually your own address).
DIGEST_TO=p.romanczuk@gmail.com
DIGEST_FROM=p.romanczuk@gmail.com

# msmtp account name — must match an `account <name>` block in ~/.msmtprc.
MSMTP_ACCOUNT=gmail

# Optional overrides (defaults shown):
# DIGEST_SUBJECT_PREFIX=[home-ops]
# CONTAINER=home-ops-postgres-1
# DB=home_ops
# DB_USER=postgres
# REPO_DIR=/home/<user>/logs-stack
