# daily-digest.env — config for ops/elitedesk/daily-digest.sh
# Copy to daily-digest.env (gitignored) and fill in. The mail *credential*
# (Gmail app password) lives in a separate 0600 file, NOT here — see README.md.

# Where the digest is sent, and the From header (both usually your own address).
DIGEST_TO=p.romanczuk@gmail.com
DIGEST_FROM=p.romanczuk@gmail.com

# Transport: 'smtplib' (Python stdlib — no install, no sudo; default) or 'msmtp'.
DIGEST_TRANSPORT=smtplib

# --- smtplib transport (default) ---
# The app password is read from this 0600 file at send time (never an env var):
SMTP_PASS_FILE=~/.config/home-ops/smtp.pass
# Optional (defaults shown):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=p.romanczuk@gmail.com   # defaults to DIGEST_FROM

# --- msmtp transport (only if DIGEST_TRANSPORT=msmtp) ---
# Account name — must match an `account <name>` block in ~/.msmtprc.
# MSMTP_ACCOUNT=gmail

# Optional overrides (defaults shown):
# DIGEST_SUBJECT_PREFIX=[home-ops]
# CONTAINER=home-ops-postgres-1
# DB=home_ops
# DB_USER=postgres
# REPO_DIR=/home/<user>/logs-stack
